{
  "name": "ask-gemini-mcp",
  "version": "1.4.1",
  "mcpName": "io.github.Lykhoyda/ask-gemini",
  "description": "MCP server for Gemini CLI integration - for Claude IDE and other IDEs",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ask-gemini-mcp": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js",
    "dev": "tsc && node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/ && tsc --noEmit",
    "format": "biome format --write src/",
    "format:check": "biome format src/",
    "check": "biome check --write src/",
    "prepublishOnly": "echo '⚠️  Remember to test locally first!' && npm run build",
    "docs:dev": "vitepress dev apps/docs",
    "docs:build": "vitepress build apps/docs",
    "docs:preview": "vitepress preview apps/docs"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "modelcontextprotocol",
    "gemini",
    "gemini-cli",
    "google-gemini",
    "claude",
    "ai",
    "ai-collaboration",
    "llm",
    "code-review",
    "second-opinion"
  ],
  "author": "Lykhoyda",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lykhoyda/ask-gemini-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Lykhoyda/ask-gemini-mcp/issues"
  },
  "homepage": "https://github.com/Lykhoyda/ask-gemini-mcp#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^22.0.0",
    "mermaid": "^11.9.0",
    "prismjs": "^1.30.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitepress": "^1.6.3",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public"
  }
}

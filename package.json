{
  "name": "ask-llm",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/docs"
  ],
  "scripts": {
    "build": "yarn workspaces foreach -At run build",
    "test": "yarn workspaces foreach -A run test",
    "lint": "yarn workspaces foreach -A run lint",
    "smoke": "sh scripts/smoke-test.sh",
    "docs:dev": "yarn workspace docs run dev",
    "docs:build": "yarn workspace docs run build",
    "docs:preview": "yarn workspace docs run preview",
    "benchmark": "yarn build && npx tsx scripts/benchmark-overhead.ts",
    "changeset": "changeset",
    "changeset:version": "changeset version && node scripts/sync-plugin-manifests.mjs",
    "changeset:status": "changeset status --verbose",
    "changeset:publish": "yarn build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.19.13",
    "husky": "^9.1.7",
    "js-tiktoken": "^1.0.21",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "yarn@4.9.1"
}
